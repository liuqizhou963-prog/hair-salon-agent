.amount-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.amount-btn {
  width: 48.6%;
  box-sizing: border-box;
  min-height: 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 2rpx solid var(--line);
  border-radius: 24rpx;
  color: var(--ink);
  background: var(--surface);
}

.amount-btn.selected {
  border-color: var(--brand);
  background: var(--surface-soft);
}

.amount-value {
  font-size: 34rpx;
  font-weight: 900;
}

.amount-bonus {
  display: block;
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 800;
}

.center-input {
  text-align: center;
}

.compact {
  margin-bottom: 0;
}
