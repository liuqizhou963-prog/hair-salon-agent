.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 56rpx 28rpx 48rpx;
  box-sizing: border-box;
  background: var(--bg);
}

.auth-card {
  width: 100%;
  padding: 48rpx 34rpx 40rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--line);
  border-radius: 28rpx;
  background: var(--surface);
  box-shadow: 0 18rpx 44rpx rgba(29,48,82,.1);
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-mark {
  width: 24rpx;
  height: 24rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: var(--brand);
}

.brand {
  color: var(--brand-dark);
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.title {
  margin-top: 38rpx;
  color: var(--ink);
  text-align: center;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: -2rpx;
}

.copy {
  max-width: 560rpx;
  margin: 14rpx auto 0;
  color: var(--muted);
  text-align: center;
  font-size: 26rpx;
  line-height: 1.6;
}

.form { margin-top: 44rpx; }

.auth-field {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.field-title {
  margin-bottom: 10rpx;
  color: var(--ink);
  font-size: 26rpx;
  font-weight: 900;
}

.input {
  width: 100%;
  height: 92rpx;
  padding: 0 26rpx;
  box-sizing: border-box;
  border: 2rpx solid #d9e0eb;
  border-radius: 18rpx;
  background: #fbfcfe;
  color: var(--ink);
  font-size: 30rpx;
}

button { border-radius: 18rpx; }

.primary {
  min-height: 88rpx;
  margin-top: 8rpx;
  color: #fff;
  background: var(--brand);
  font-size: 29rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 24rpx rgba(47,111,237,.2);
}

.secondary {
  min-height: 72rpx;
  margin-top: 12rpx;
  color: var(--brand-dark);
  background: transparent;
  font-size: 27rpx;
  font-weight: 900;
}

.divider {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 10rpx 0 4rpx;
  color: var(--muted);
  font-size: 24rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: var(--line);
}

.wechat {
  min-height: 84rpx;
  margin-top: 12rpx;
  color: #14804d;
  background: #edf9f1;
  border: 2rpx solid #b8e3c9;
  font-size: 28rpx;
  font-weight: 900;
}

.error {
  margin-top: 24rpx;
  color: var(--danger);
  text-align: center;
  font-size: 26rpx;
  line-height: 1.5;
}
