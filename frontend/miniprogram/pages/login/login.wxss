.page { min-height: 100vh; padding: 88rpx 48rpx; box-sizing: border-box; background: #fffaf7; }
.brand { color: #4f96ce; font-size: 28rpx; letter-spacing: 2rpx; }
.title { margin-top: 56rpx; color: #18232d; font-size: 64rpx; font-weight: 700; line-height: 1.1; }
.copy { margin-top: 24rpx; color: #87908b; font-size: 27rpx; line-height: 1.7; }
.form { margin-top: 64rpx; }
.input { height: 96rpx; margin-bottom: 24rpx; padding: 0 28rpx; box-sizing: border-box; border: 1rpx solid #dfe5e2; border-radius: 12rpx; background: #fff; color: #18232d; }
button { border-radius: 12rpx; }
.primary { margin-top: 12rpx; background: #4f96ce; color: #fff; }
.secondary { margin-top: 20rpx; color: #4f96ce; background: transparent; border: 1rpx solid #b7d4ea; }
.error { margin-top: 24rpx; color: #c96b5c; font-size: 26rpx; }
