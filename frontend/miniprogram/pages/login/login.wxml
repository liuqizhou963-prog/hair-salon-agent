<view class="page">
  <view class="auth-card">
    <view class="brand-row">
      <view class="brand-mark"></view>
      <text class="brand">HengYi Salon</text>
    </view>
    <view class="title">{{registerMode ? '创建账户' : '欢迎回来'}}</view>
    <view class="copy">{{registerMode ? '注册后即可查看真实排档并管理预约。' : '登录后查看你的预约和会员权益。'}}</view>
    <view class="form">
      <view wx:if="{{registerMode}}" class="auth-field">
        <text class="field-title">姓名</text>
        <input class="input" placeholder="请输入姓名" value="{{name}}" data-field="name" bindinput="onInput" />
      </view>
      <view class="auth-field">
        <text class="field-title">手机号</text>
        <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" data-field="phone" bindinput="onInput" />
      </view>
      <view class="auth-field">
        <text class="field-title">密码</text>
        <input class="input" password placeholder="至少 8 位密码" value="{{password}}" data-field="password" bindinput="onInput" />
      </view>
      <button class="primary" loading="{{loading}}" bindtap="submit">{{registerMode ? '注册并登录' : '登录'}}</button>
      <button class="secondary" bindtap="toggleMode">{{registerMode ? '已有账号，去登录' : '没有账号，去注册'}}</button>
      <view class="divider">
        <view class="divider-line"></view>
        <text>或</text>
        <view class="divider-line"></view>
      </view>
      <button class="wechat" loading="{{loading}}" bindtap="wechatLogin">微信登录</button>
      <view wx:if="{{error}}" class="error">{{error}}</view>
    </view>
  </view>
</view>
