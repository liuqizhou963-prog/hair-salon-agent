<view class="page">
  <view class="brand">HengYi Salon</view>
  <view class="title">{{registerMode ? '创建账户' : '欢迎回来'}}</view>
  <view class="copy">{{registerMode ? '注册后即可查看真实排档并管理预约。' : '登录后查看你的预约和会员权益。'}}</view>
  <view class="form">
    <input wx:if="{{registerMode}}" class="input" placeholder="姓名" value="{{name}}" data-field="name" bindinput="onInput" />
    <input class="input" type="number" placeholder="手机号" value="{{phone}}" data-field="phone" bindinput="onInput" />
    <input class="input" password placeholder="密码（至少 8 位）" value="{{password}}" data-field="password" bindinput="onInput" />
    <button class="primary" loading="{{loading}}" bindtap="submit">{{registerMode ? '注册并登录' : '登录'}}</button>
    <button class="secondary" bindtap="toggleMode">{{registerMode ? '已有账号，去登录' : '没有账号，去注册'}}</button>
    <view wx:if="{{error}}" class="error">{{error}}</view>
  </view>
</view>
