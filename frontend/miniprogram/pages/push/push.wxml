<view class="page">
  <view class="hero-band">
    <view class="hero-brand">
      <view class="hair-logo"></view>
      <text>HengYi Salon</text>
    </view>
    <text class="hero-title">站内
通知</text>
    <text class="hero-copy">预约变更、积分到账和退款进度都会显示在这里。</text>
  </view>

  <view class="card line-card">
    <view wx:for="{{notifications}}" wx:key="notification_id" class="line-item" data-id="{{item.notification_id}}" bindtap="read">
      <view><text class="line-title">{{item.title}}</text><text class="line-meta">{{item.body}}</text></view>
      <text class="line-meta">{{item.is_read ? '已读' : '未读'}}</text>
    </view>
    <view wx:if="{{!notifications.length}}" class="line-item"><text class="line-meta">暂时没有通知</text></view>
  </view>
</view>
