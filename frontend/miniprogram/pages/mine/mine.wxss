.mine-page {
  padding-top: 0;
}

.wallet-hero {
  margin: 0 -28rpx 0;
  padding: 48rpx 40rpx 88rpx;
  color: #ffffff;
  background: linear-gradient(180deg, #78b7e7 0%, #67a7d8 100%);
  overflow: hidden;
  position: relative;
}

.wallet-label {
  display: block;
  margin-top: 36rpx;
  color: rgba(255,255,255,.78);
  font-size: 24rpx;
}

.wallet-balance {
  display: block;
  margin-top: 12rpx;
  font-size: 82rpx;
  line-height: 1;
  font-weight: 900;
}

.wallet-sub {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 12rpx;
  color: rgba(255,255,255,.82);
  font-size: 24rpx;
}

.wallet-sub text {
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.pill.gold {
  color: #7a5210;
  background: #fef3c7;
}

.wallet-actions {
  display: flex;
  margin-top: 18rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 2;
}

.wallet-action-btn {
  flex: 1;
  min-width: 0;
  min-height: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
  margin-left: 12rpx;
  border: 2rpx solid #eadfd8;
  border-radius: 28rpx;
  color: #201c1a;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(77,51,32,.08);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
}

.wallet-action-btn:first-child {
  margin-left: 0;
}

.wallet-action-btn text:last-child {
  margin-top: 12rpx;
}

.action-mark {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: #ffffff;
  background: #1f746b;
  font-size: 22rpx;
  font-weight: 900;
}

.metric-card {
  display: flex;
  overflow: hidden;
  border: 2rpx solid #eadfd8;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 44rpx rgba(77,51,32,.08);
}

.metric-cell {
  flex: 1;
  min-width: 0;
  padding: 26rpx;
  border-right: 2rpx solid #eadfd8;
  text-align: left;
}

.metric-cell:last-child {
  border-right: 0;
}

.metric-cell text:first-child {
  display: block;
  color: #736760;
  font-size: 24rpx;
  font-weight: 800;
}

.metric-value {
  display: block;
  margin-top: 12rpx;
  color: #4f96ce;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.15;
}

.clickable {
  color: #201c1a;
  background: #ffffff;
}

.link-btn {
  flex: 0 0 auto;
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #1f746b;
  background: #e2f1ed;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 32rpx;
}

.empty-card text,
.empty-card button {
  margin-top: 16rpx;
}

.empty-card text:first-child {
  margin-top: 0;
}

.appointment-list {
  display: flex;
  flex-direction: column;
}

.appointment-card {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 20rpx;
  border: 2rpx solid #eadfd8;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(77,51,32,.07);
  overflow: hidden;
}

.appointment-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #edf2f0;
}

.appointment-info {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.appointment-title {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 900;
}

.appointment-time {
  display: block;
  margin-top: 8rpx;
  color: #1f746b;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
}

.appointment-card .pill {
  flex: 0 0 auto;
  margin-left: 14rpx;
}

.line-card {
  padding: 0;
}

.line-item {
  width: 100%;
  box-sizing: border-box;
  padding: 0 30rpx;
  justify-content: flex-start;
  text-align: left;
}

.line-item > view {
  display: block;
  flex: 1;
  min-width: 0;
  text-align: left;
}

.line-item .line-title,
.line-item .line-meta {
  text-align: left;
}
