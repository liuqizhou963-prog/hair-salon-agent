<view class="page">
  <view class="hero-band">
    <view class="hero-brand">
      <view class="hair-logo"></view>
      <text>HengYi Salon</text>
    </view>
    <text class="hero-title">个人
资料</text>
    <text class="hero-copy">维护姓名、手机号和生日信息，方便门店为你同步预约与会员权益。</text>
  </view>

  <view class="card form-card">
    <label class="field-label">
      <text>姓名</text>
      <input class="text-input" value="{{name}}" bindinput="onNameInput" />
    </label>
    <label class="field-label">
      <text>手机号</text>
      <input class="text-input" type="number" value="{{phone}}" bindinput="onPhoneInput" />
    </label>
    <label class="field-label">
      <text>生日（MM-DD）</text>
      <input class="text-input" value="{{birthday}}" bindinput="onBirthdayInput" />
    </label>
    <button class="primary-btn" bindtap="save">保存</button>
  </view>
</view>
