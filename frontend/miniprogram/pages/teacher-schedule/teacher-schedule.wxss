.teacher-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  overflow: hidden;
}

.teacher-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 30rpx;
  background: #edf2f0;
}

.teacher-main {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.teacher-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 900;
}

.teacher-card .pill {
  flex: 0 0 auto;
  margin-left: 18rpx;
}

.pill.dark {
  color: #ffffff;
  background: var(--brand-dark);
}

.slot-day {
  margin-top: 28rpx;
}

.slot-day-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 900;
}

.slot-day-head text:first-child {
  flex: 1;
  min-width: 0;
}

.slot-day-head .muted {
  flex: 0 0 auto;
  margin-left: 20rpx;
}

.slot-grid {
  overflow: hidden;
}

.slot-card {
  width: 48%;
  box-sizing: border-box;
  min-height: 184rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  float: left;
  margin-bottom: 16rpx;
  padding: 22rpx;
  border-radius: 32rpx;
  border: 2rpx solid #c9d9fb;
  color: var(--ink);
  background: #f5f8ff;
  text-align: left;
  overflow: hidden;
}

.slot-left {
  margin-right: 4%;
}

.slot-right {
  margin-right: 0;
}

.slot-card.afternoon {
  border-color: #b9cef8;
  background: var(--surface-soft);
}

.slot-card.evening {
  border-color: #d7def7;
  background: #f5f7ff;
}

.slot-period {
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.slot-time {
  display: block;
  margin-top: 8rpx;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 900;
}

.slot-note {
  display: block;
  margin-top: 8rpx;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  color: var(--brand-dark);
  background: rgba(255,255,255,.72);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 38rpx;
}
