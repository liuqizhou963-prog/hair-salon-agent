.stylist-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.stylist-card {
  width: 48%;
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin-bottom: 18rpx;
  padding: 12rpx;
  border: 2rpx solid var(--line);
  border-radius: 24rpx;
  background: rgba(255,255,255,.96);
  box-shadow: 0 12rpx 32rpx rgba(29,48,82,.08);
  overflow: hidden;
  box-sizing: border-box;
}

.stylist-card.card-left {
  margin-right: 4%;
}

.stylist-card.card-right {
  margin-right: 0;
}

.stylist-card.selected {
  border-color: rgba(47,111,237,.42);
  box-shadow: 0 16rpx 36rpx rgba(47,111,237,.14);
}

.stylist-main {
  display: flex;
  flex-direction: column;
  color: var(--ink);
  text-align: left;
}

.stylist-photo-wrap {
  width: 100%;
  height: 250rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: var(--surface-soft);
}

.stylist-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.stylist-body {
  margin-top: 16rpx;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
}

.stylist-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 26rpx;
  line-height: 1.25;
  font-weight: 900;
}

.verified {
  width: 32rpx;
  height: 32rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 10rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #31c95c;
  font-size: 22rpx;
  font-weight: 900;
}

.stylist-bio {
  min-height: 70rpx;
  margin-top: 10rpx;
  display: -webkit-box;
  overflow: hidden;
  color: var(--muted);
  font-size: 21rpx;
  line-height: 1.5;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.stylist-foot {
  display: flex;
  flex-direction: column;
  margin-top: 12rpx;
  min-width: 0;
}

.stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--ink);
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
  min-width: 0;
}

.stat {
  display: inline-block;
}

.follow-btn {
  width: 100%;
  min-height: 72rpx;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: var(--ink);
  background: var(--bg);
  box-shadow: inset 0 0 0 2rpx var(--line), 0 8rpx 18rpx rgba(29,48,82,.06);
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.follow-btn.active {
  color: #ffffff;
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
  box-shadow: 0 10rpx 22rpx rgba(47,111,237,.18);
}

.hero-secondary {
  color: #ffffff;
  background: rgba(255,255,255,.18);
  border: 2rpx solid rgba(255,255,255,.38);
}
