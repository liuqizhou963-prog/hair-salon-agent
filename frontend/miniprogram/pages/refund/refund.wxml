<view class="page">
  <view class="hero-band">
    <view class="hero-brand">
      <view class="hair-logo"></view>
      <text>HengYi Salon</text>
    </view>
    <text class="hero-title">余额
退款</text>
    <text class="hero-copy">可将会员余额退回原支付账户，提交后由门店确认处理。</text>
  </view>

  <view class="metric-card">
    <view class="metric-cell">
      <text>可退余额</text>
      <text class="metric-value">￥{{user.balance}}</text>
    </view>
    <view class="metric-cell">
      <text>预计到账</text>
      <text class="metric-value small">1-3天</text>
    </view>
  </view>

  <view class="section">
    <view class="card refund-card">
      <text class="refund-title">退款金额</text>
      <text class="muted">默认退回全部可用余额，也可以到店后由店员调整。</text>
      <input
        class="refund-input"
        type="number"
        min="1"
        max="{{user.balance}}"
        value="{{amount}}"
        placeholder="退款金额"
        bindinput="onAmountInput"
      />
      <button class="primary-btn" bindtap="submitRefund">申请退款</button>
    </view>
  </view>
</view>
