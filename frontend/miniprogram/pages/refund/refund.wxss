.metric-card {
  display: flex;
  overflow: hidden;
  border: 2rpx solid var(--line);
  border-radius: 24rpx;
  background: var(--surface);
  box-shadow: 0 12rpx 32rpx rgba(29,48,82,.08);
}

.metric-cell {
  flex: 1;
  min-width: 0;
  padding: 26rpx;
  border-right: 2rpx solid var(--line);
}

.metric-cell:last-child {
  border-right: 0;
}

.metric-cell text:first-child {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
}

.metric-value {
  display: block;
  margin-top: 12rpx;
  color: var(--brand);
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.15;
}

.metric-value.small {
  font-size: 32rpx;
}

.refund-card {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
}

.refund-card > text,
.refund-card > input,
.refund-card > button {
  margin-top: 18rpx;
}

.refund-card > text:first-child {
  margin-top: 0;
}

.refund-title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 900;
}

.refund-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--line);
  border-radius: 20rpx;
  background: var(--surface);
  font-size: 30rpx;
}
