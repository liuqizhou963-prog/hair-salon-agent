page {
  min-height: 100%;
  background: #f8f3ef;
  color: #201c1a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: normal;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding-bottom: calc(168rpx + env(safe-area-inset-bottom));
  background: #fffaf7;
  overflow: hidden;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 20;
  min-height: 96rpx;
  display: grid;
  grid-template-columns: 88rpx 1fr 88rpx;
  align-items: center;
  padding: calc(12rpx + env(safe-area-inset-top)) 28rpx 12rpx;
  background: rgba(255, 250, 247, .9);
  border-bottom: 1rpx solid rgba(234, 223, 216, .72);
  backdrop-filter: blur(24rpx);
}

.top-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
}

.icon-btn,
.menu-btn {
  width: 88rpx;
  height: 88rpx;
  display: grid;
  place-items: center;
  border-radius: 28rpx;
}

.icon-btn {
  background: #f2ebe6;
}

.menu-lines,
.menu-lines::before,
.menu-lines::after {
  width: 34rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #1f746b;
}

.menu-lines {
  position: relative;
}

.menu-lines::before,
.menu-lines::after {
  content: "";
  position: absolute;
  left: 0;
}

.menu-lines::before {
  top: -12rpx;
}

.menu-lines::after {
  top: 12rpx;
}

.menu-lines.white,
.menu-lines.white::before,
.menu-lines.white::after {
  background: #ffffff;
}

.hero {
  position: relative;
  min-height: 980rpx;
  padding: 30rpx 44rpx 112rpx;
  overflow: hidden;
  color: #ffffff;
  background:
    radial-gradient(circle at 18% 20%, rgba(255,255,255,.2), transparent 24%),
    linear-gradient(180deg, #78b7e7 0%, #67a7d8 100%);
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 3;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.hair-logo {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  border: 4rpx solid #edff57;
  border-left-color: transparent;
  transform: rotate(-28deg);
  position: relative;
}

.hair-logo::after {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 25rpx;
  width: 38rpx;
  height: 18rpx;
  border-top: 4rpx solid #edff57;
  border-radius: 50%;
  transform: rotate(-18deg);
}

.headline {
  position: relative;
  z-index: 3;
  margin-top: 44rpx;
}

.h1 {
  display: block;
  color: #ffffff;
  font-size: 128rpx;
  line-height: .94;
  letter-spacing: 0;
  font-weight: 500;
}

.proof {
  display: flex;
  align-items: center;
  margin: -76rpx 0 0 420rpx;
  min-height: 96rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  margin-left: -18rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,.88);
  background:
    radial-gradient(circle at 50% 35%, #ffe0c4 0 18%, transparent 19%),
    linear-gradient(135deg, #8d5f44, #f5c28a 48%, #475f89);
}

.avatar.alt {
  background:
    radial-gradient(circle at 50% 35%, #f7c6b1 0 18%, transparent 19%),
    linear-gradient(135deg, #3f2a24, #e8a17a 46%, #f5d347);
}

.member-badge {
  width: 100rpx;
  height: 100rpx;
  margin-left: -16rpx;
  display: grid;
  place-items: center;
  border-radius: 50%;
  color: #397ebd;
  background: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.lead {
  display: block;
  width: 520rpx;
  margin: 44rpx 0 0 44rpx;
  color: rgba(255,255,255,.78);
  font-size: 32rpx;
  line-height: 1.35;
}

.hero-actions {
  position: relative;
  z-index: 6;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 44rpx;
}

.primary-action,
.secondary-action {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.primary-action {
  color: #201c1a;
  background: #edff57;
  box-shadow: 0 28rpx 56rpx rgba(54,83,32,.22);
}

.secondary-action {
  color: #ffffff;
  background: rgba(255,255,255,.18);
  border: 2rpx solid rgba(255,255,255,.38);
  backdrop-filter: blur(16rpx);
}

.salon-scene {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 490rpx;
  z-index: 2;
  pointer-events: none;
}

.hair-mass {
  position: absolute;
  left: 52rpx;
  right: 48rpx;
  bottom: -100rpx;
  height: 420rpx;
  border-radius: 56% 56% 38% 38%;
  background:
    radial-gradient(ellipse at 26% 20%, rgba(255,255,255,.96), transparent 32%),
    radial-gradient(ellipse at 70% 12%, rgba(255,255,255,.72), transparent 27%),
    repeating-linear-gradient(100deg, rgba(255,255,255,.48) 0 8rpx, rgba(191,206,210,.24) 10rpx 18rpx),
    linear-gradient(145deg, #f7f8f3, #bfc7c9 55%, #f6f4ed);
  box-shadow: inset 0 36rpx 88rpx rgba(255,255,255,.72), 0 -40rpx 70rpx rgba(69,123,154,.18);
}

.hair-mass::before,
.hair-mass::after {
  content: "";
  position: absolute;
  left: 50rpx;
  right: 50rpx;
  top: 68rpx;
  height: 200rpx;
  border-radius: 50%;
  border-top: 4rpx solid rgba(99,88,80,.18);
  transform: rotate(-8deg);
}

.hair-mass::after {
  left: 92rpx;
  right: 124rpx;
  top: 104rpx;
  transform: rotate(10deg);
  border-top-color: rgba(255,255,255,.66);
}

.stylist {
  position: absolute;
  width: 128rpx;
  height: 216rpx;
  bottom: 264rpx;
  z-index: 3;
}

.stylist.one {
  left: 156rpx;
  transform: rotate(-12deg);
}

.stylist.two {
  left: 356rpx;
  bottom: 300rpx;
}

.stylist.three {
  right: 136rpx;
  transform: rotate(12deg);
}

.haircap {
  width: 56rpx;
  height: 28rpx;
  margin: 0 auto -18rpx;
  border-radius: 50% 50% 30% 30%;
  background: #14110f;
  position: relative;
  z-index: 2;
}

.head {
  width: 44rpx;
  height: 44rpx;
  margin: 0 auto -2rpx;
  border-radius: 50%;
  background: #efb89d;
}

.body {
  width: 92rpx;
  height: 112rpx;
  margin: 0 auto;
  border-radius: 36rpx 36rpx 20rpx 20rpx;
  background: linear-gradient(180deg, #1d1a18, #3c3129);
  position: relative;
}

.body::before,
.body::after {
  content: "";
  position: absolute;
  top: 36rpx;
  width: 24rpx;
  height: 108rpx;
  border-radius: 999rpx;
  background: #1d1a18;
  transform-origin: top center;
}

.body::before {
  left: -12rpx;
  transform: rotate(37deg);
}

.body::after {
  right: -12rpx;
  transform: rotate(-37deg);
}

.legs {
  width: 84rpx;
  height: 68rpx;
  margin: -6rpx auto 0;
  border-radius: 0 0 24rpx 24rpx;
  background:
    linear-gradient(90deg, transparent 0 42%, #171514 42% 58%, transparent 58%),
    linear-gradient(90deg, #24201e 0 48%, transparent 48% 52%, #24201e 52%);
}

.tool {
  position: absolute;
  height: 6rpx;
  width: 128rpx;
  background: #111111;
  border-radius: 999rpx;
  transform-origin: left center;
}

.one .tool {
  left: 66rpx;
  top: 116rpx;
  transform: rotate(28deg);
}

.two .tool {
  left: 62rpx;
  top: 104rpx;
  width: 156rpx;
  transform: rotate(89deg);
}

.three .tool {
  right: 68rpx;
  top: 116rpx;
  transform: rotate(152deg);
}

.content {
  padding: 0 32rpx 48rpx;
  position: relative;
  z-index: 10;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: -52rpx;
  position: relative;
  z-index: 12;
}

.quick-card {
  min-height: 156rpx;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 12rpx;
  color: #201c1a;
  background: #ffffff;
  border: 2rpx solid #eadfd8;
  border-radius: 24rpx;
  box-shadow: 0 20rpx 56rpx rgba(77,51,32,.1);
  font-size: 24rpx;
  font-weight: 900;
}

.quick-icon,
.bottom-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  color: #1f746b;
}

.quick-icon.calendar,
.bottom-icon.calendar {
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
}

.quick-icon.calendar::before,
.bottom-icon.calendar::before {
  content: "";
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  top: 12rpx;
  height: 4rpx;
  background: currentColor;
}

.quick-icon.order {
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
}

.quick-icon.appointment {
  border: 4rpx solid currentColor;
  border-radius: 10rpx;
}

.quick-icon.appointment::before {
  content: "";
  position: absolute;
  left: 9rpx;
  top: -9rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #fffaf7;
  border: 4rpx solid currentColor;
}

.quick-icon.appointment::after {
  content: "";
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 9rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 -12rpx 0 currentColor;
}

.quick-icon.order::before,
.quick-icon.order::after {
  content: "";
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  height: 4rpx;
  background: currentColor;
}

.quick-icon.order::before {
  top: 14rpx;
}

.quick-icon.order::after {
  top: 26rpx;
}

.quick-icon.wallet {
  border: 4rpx solid currentColor;
  border-radius: 10rpx;
}

.quick-icon.wallet::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 14rpx;
  height: 4rpx;
  background: currentColor;
}

.section {
  margin-top: 44rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 900;
}

.link-btn {
  min-height: 72rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  color: #1f746b;
  background: #e2f1ed;
  font-size: 26rpx;
  font-weight: 900;
}

.member-card,
.teacher-card {
  border: 2rpx solid #eadfd8;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(77,51,32,.08);
}

.member-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
}

.metric {
  padding: 32rpx;
  border-right: 2rpx solid #eadfd8;
}

.metric:last-child {
  border-right: 0;
}

.metric text:first-child {
  display: block;
  color: #736760;
  font-size: 24rpx;
  font-weight: 700;
}

.metric-value {
  display: block;
  margin-top: 10rpx;
  color: #9f4e44;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 900;
}

.teacher-card {
  width: 100%;
  padding: 28rpx;
  color: #201c1a;
}

.teacher-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.teacher-avatar {
  width: 96rpx;
  height: 96rpx;
  display: grid;
  place-items: center;
  border-radius: 32rpx;
  color: #ffffff;
  background: #5a4b87;
  font-size: 32rpx;
  font-weight: 900;
}

.teacher-main {
  min-width: 0;
  flex: 1;
  text-align: left;
}

.teacher-name {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
}

.teacher-meta {
  display: block;
  margin-top: 8rpx;
  color: #736760;
  font-size: 26rpx;
  line-height: 1.35;
}

.time-pill {
  min-width: 136rpx;
  min-height: 68rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #1f746b;
  background: #e2f1ed;
  font-size: 26rpx;
  font-weight: 900;
}

.slot-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
  color: #201c1a;
  font-size: 26rpx;
  font-weight: 900;
}

.slot-head text:last-child {
  color: #8b7d75;
  font-size: 22rpx;
  font-weight: 800;
}

.slot-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
}

.slot-card {
  min-height: 148rpx;
  display: grid;
  align-content: center;
  justify-items: start;
  gap: 8rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid #eadfd8;
  color: #201c1a;
  background: #f9f4f0;
  text-align: left;
}

.slot-card.primary {
  border-color: #b7d7d0;
  background: #e2f1ed;
  box-shadow: inset 0 0 0 2rpx rgba(31,116,107,.1);
}

.slot-card.warm {
  border-color: #f3dac3;
  background: #fff2e6;
}

.slot-card.cool {
  border-color: #d7d3ef;
  background: #f1efff;
}

.slot-period {
  color: #736760;
  font-size: 22rpx;
  font-weight: 800;
}

.slot-time {
  color: #201c1a;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 900;
}

.slot-status {
  min-height: 36rpx;
  display: inline-flex;
  align-items: center;
  padding: 0 12rpx;
  border-radius: 999rpx;
  color: #1f746b;
  background: rgba(255,255,255,.72);
  font-size: 20rpx;
  font-weight: 900;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(144rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  background: rgba(255,255,255,.96);
  border-top: 2rpx solid #eadfd8;
  box-shadow: 0 -20rpx 56rpx rgba(77,51,32,.1);
  z-index: 30;
}

.bottom-tab {
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 8rpx;
  color: #87908b;
  font-size: 22rpx;
  font-weight: 800;
}

.bottom-tab.active {
  color: #9f4e44;
}

.bottom-icon.home::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 16rpx;
  width: 30rpx;
  height: 24rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
}

.bottom-icon.home::after {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 5rpx;
  width: 28rpx;
  height: 28rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: rotate(45deg);
}
