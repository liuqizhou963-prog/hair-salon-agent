<view class="page">
  <view class="topbar">
    <view></view>
    <text class="top-title">恒艺美发</text>
    <button class="icon-btn" plain bindtap="openMenu" aria-label="打开菜单">
      <view class="menu-lines"></view>
    </button>
  </view>

  <view class="hero">
    <view class="brand-row">
      <view class="brand">
        <view class="hair-logo"></view>
        <text>HengYi Salon</text>
      </view>
      <button class="menu-btn" plain bindtap="openMenu" aria-label="打开菜单">
        <view class="menu-lines white"></view>
      </button>
    </view>

    <view class="headline">
      <text class="h1">焕新</text>
      <text class="h1">你的专属</text>
      <text class="h1">发型</text>

      <view class="proof" aria-label="+2k 会员">
        <view class="avatar"></view>
        <view class="avatar alt"></view>
        <view class="member-badge">+2k</view>
      </view>

      <text class="lead">查看常用美发老师的可约时间，管理余额、积分与订单。</text>
    </view>

    <view class="hero-actions">
      <button class="primary-action" bindtap="goBooking">立即预约</button>
      <button class="secondary-action" bindtap="goFavorite">只看常用老师</button>
    </view>

    <view class="salon-scene" aria-hidden="true">
      <view class="stylist one">
        <view class="haircap"></view>
        <view class="head"></view>
        <view class="body"></view>
        <view class="legs"></view>
        <view class="tool"></view>
      </view>
      <view class="stylist two">
        <view class="haircap"></view>
        <view class="head"></view>
        <view class="body"></view>
        <view class="legs"></view>
        <view class="tool"></view>
      </view>
      <view class="stylist three">
        <view class="haircap"></view>
        <view class="head"></view>
        <view class="body"></view>
        <view class="legs"></view>
        <view class="tool"></view>
      </view>
      <view class="hair-mass"></view>
    </view>
  </view>

  <view class="content">
    <view class="quick-grid" aria-label="快捷入口">
      <button class="quick-card" bindtap="goBooking">
        <view class="quick-icon calendar"></view>
        <text>预约排档</text>
      </button>
      <button class="quick-card" bindtap="goAppointments">
        <view class="quick-icon appointment"></view>
        <text>我的预约</text>
      </button>
      <button class="quick-card" bindtap="goOrders">
        <view class="quick-icon order"></view>
        <text>我的订单</text>
      </button>
      <button class="quick-card" bindtap="goWallet">
        <view class="quick-icon wallet"></view>
        <text>余额积分</text>
      </button>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">我的会员卡</text>
        <button class="link-btn" bindtap="goWallet">查看明细</button>
      </view>
      <view class="member-card">
        <view class="metric">
          <text>账户余额</text>
          <text class="metric-value">￥328</text>
        </view>
        <view class="metric">
          <text>可用积分</text>
          <text class="metric-value">1280</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">常用老师排档</text>
        <button class="link-btn" bindtap="goBooking">全部老师</button>
      </view>
      <view class="teacher-card">
        <view class="teacher-top">
          <view class="teacher-avatar">张</view>
          <view class="teacher-main">
            <text class="teacher-name">张三 老师</text>
            <text class="teacher-meta">烫、染、护理 · 已设为常用老师</text>
          </view>
          <text class="time-pill">今天可约</text>
        </view>
        <view class="slot-head">
          <text>可选时间</text>
          <text>点时间段直接预约</text>
        </view>
        <view class="slot-grid">
          <button
            wx:for="{{availableSlots}}"
            wx:key="time"
            class="slot-card {{item.tone}}"
            bindtap="goBooking"
          >
            <text class="slot-period">{{item.period}}</text>
            <text class="slot-time">{{item.time}}</text>
            <text class="slot-status">{{item.status}}</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-nav">
    <button class="bottom-tab active" bindtap="stayHome">
      <view class="bottom-icon home"></view>
      <text>首页</text>
    </button>
    <button class="bottom-tab" bindtap="goBooking">
      <view class="bottom-icon calendar"></view>
      <text>预约</text>
    </button>
  </view>
</view>
