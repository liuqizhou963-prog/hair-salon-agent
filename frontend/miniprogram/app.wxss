page {
  min-height: 100%;
  --bg: #f5f7fb;
  --surface: #ffffff;
  --surface-soft: #eef4ff;
  --ink: #172033;
  --muted: #748096;
  --line: #e4e9f1;
  --brand: #2f6fed;
  --brand-dark: #1d49ad;
  --success: #1d9565;
  --gold: #bf7b17;
  --gold-soft: #fff5df;
  --danger: #c93d4d;
  color: var(--ink);
  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: normal;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 148rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.hero-band {
  margin: -28rpx -28rpx 28rpx;
  padding: 44rpx 36rpx 52rpx;
  color: #ffffff;
  background: linear-gradient(180deg, var(--brand) 0%, var(--brand-dark) 100%);
  overflow: hidden;
  position: relative;
}

.hero-brand {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 900;
  opacity: .92;
}

.hero-brand text {
  margin-left: 14rpx;
}

.hair-logo {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid rgba(255,255,255,.72);
  border-radius: 50%;
  box-sizing: border-box;
}

.hero-title {
  display: block;
  margin-top: 34rpx;
  font-size: 72rpx;
  line-height: 1;
  font-weight: 700;
  white-space: pre-line;
}

.hero-copy {
  display: block;
  max-width: 560rpx;
  margin-top: 14rpx;
  color: rgba(255,255,255,.82);
  font-size: 26rpx;
  line-height: 1.45;
}

.hero-actions {
  display: flex;
  margin-top: 34rpx;
}

.hero-actions button {
  flex: 1;
  min-width: 0;
}

.hero-actions button + button {
  margin-left: 20rpx;
}

.section {
  margin-top: 32rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
}

.muted {
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.4;
}

.section-head > .muted {
  flex: 0 0 auto;
  max-width: 260rpx;
  text-align: right;
}

.card {
  border: 2rpx solid var(--line);
  border-radius: 24rpx;
  background: var(--surface);
  box-shadow: 0 12rpx 32rpx rgba(29,48,82,.08);
}

.metric-card {
  display: flex;
  overflow: hidden;
  border: 2rpx solid var(--line);
  border-radius: 24rpx;
  background: var(--surface);
  box-shadow: 0 12rpx 32rpx rgba(29,48,82,.08);
}

.metric-cell {
  flex: 1;
  min-width: 0;
  padding: 26rpx;
  border-right: 2rpx solid var(--line);
  text-align: left;
}

.metric-cell:last-child {
  border-right: 0;
}

.metric-cell text:first-child {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
}

.metric-value {
  display: block;
  margin-top: 12rpx;
  color: var(--brand);
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 900;
}

.metric-value.small {
  font-size: 32rpx;
}

input {
  box-sizing: border-box;
}

.grid {
  display: flex;
  flex-direction: column;
}

.grid > view,
.grid > button {
  margin-bottom: 24rpx;
}

.grid > view:last-child,
.grid > button:last-child {
  margin-bottom: 0;
}

.line-card {
  padding: 0 30rpx;
}

.line-item {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 2rpx solid var(--line);
  color: var(--ink);
  text-align: left;
}

.line-item > view,
.line-item > text:first-child {
  flex: 1;
  min-width: 0;
}

.line-item > switch,
.line-item > .chevron,
.line-item > .line-meta {
  flex: 0 0 auto;
  margin-left: 24rpx;
}

.line-item:last-child {
  border-bottom: 0;
}

.line-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 900;
}

.line-meta {
  display: block;
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.45;
}

.chevron {
  color: var(--muted);
  font-size: 34rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 32rpx;
}

.empty-card text,
.empty-card button {
  margin-top: 16rpx;
}

.empty-card text:first-child {
  margin-top: 0;
}

.empty-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  color: var(--brand);
  background: var(--surface-soft);
  font-size: 28rpx;
  font-weight: 900;
}

.form-card {
  display: flex;
  flex-direction: column;
  padding: 32rpx;
}

.form-card > view,
.form-card > label,
.form-card > input,
.form-card > button,
.form-card > text {
  margin-top: 20rpx;
}

.form-card > view:first-child,
.form-card > label:first-child,
.form-card > input:first-child,
.form-card > button:first-child,
.form-card > text:first-child {
  margin-top: 0;
}

.field-label {
  display: flex;
  flex-direction: column;
  color: var(--ink);
  font-size: 26rpx;
  font-weight: 900;
}

.field-label input {
  margin-top: 10rpx;
}

.text-input {
  width: 100%;
  min-height: 92rpx;
  padding: 0 26rpx;
  border: 2rpx solid var(--line);
  border-radius: 20rpx;
  background: var(--surface);
  color: var(--ink);
  font-size: 30rpx;
}

.primary-btn,
.secondary-btn,
.pill-btn {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.primary-btn {
  color: #ffffff;
  background: var(--brand);
}

.primary-btn[disabled] {
  opacity: .52;
}

.secondary-btn {
  color: var(--brand-dark);
  background: var(--surface-soft);
}

.pill {
  min-height: 48rpx;
  display: inline-flex;
  align-items: center;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: var(--brand-dark);
  background: var(--surface-soft);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
}
