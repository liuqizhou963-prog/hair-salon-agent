# ⚠️ 此文件会被 git 跟踪并上传！只能放占位符，绝不能填真实 key。真 key 请放在 .env（已被 git 忽略）。
# ===== LLM 配置 =====
LLM_API_KEY=your-key-here
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat
OLLAMA_BASE_URL=http://localhost:11434

# DeepSeek 示例：
# LLM_API_KEY=your-deepseek-key
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# Ollama OpenAI-compatible 示例：
# LLM_API_KEY=ollama
# LLM_API_BASE=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434

# Embedding 只在 RAG_USE_CHROMA=true 时使用，可选值：openai / ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ===== 数据库 (留空则自动使用 SQLite) =====
DATABASE_URL=

# ===== ChromaDB =====
RAG_USE_CHROMA=false
CHROMA_PERSIST_DIR=./chroma_data

# ===== 调试 =====
DEBUG=false

# ===== 管理员操作 =====
# 留空时方便本地演示；设置后 /api/init-db 需要请求头 X-Admin-Token。
ADMIN_TOKEN=

# ===== 登录与演示账号 =====
# AUTH_SECRET_KEY 必须在真实环境替换成随机长字符串，不能使用代码默认值。
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
# 员工账号禁止公开注册。填写后，初始化脚本会给示例发型师设置这个密码。
DEMO_STAFF_PASSWORD=replace-with-local-staff-password
DEMO_ADMIN_PHONE=13900009999
DEMO_ADMIN_NAME=演示管理员
DEMO_ADMIN_PASSWORD=replace-with-local-admin-password
